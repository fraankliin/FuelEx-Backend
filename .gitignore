# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Entornos virtuales
.env
.venv
env/
venv/
ENV/

# Variables de entorno
.env.*
*.env

# Archivos de distribución / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# Archivos de logs
*.log
logs/

# Archivos de test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
pytest_cache/

# Archivos de Jupyter Notebook
.ipynb_checkpoints

# Archivos de IDEs / editores
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Archivos del sistema operativo
.DS_Store
Thumbs.db

# Archivos temporales
*.swp
*.tmp

# Archivos SQLite (opcional si no quieres versionarlos)
*.sqlite3
*.db

# Archivos de Docker (si aplica)
docker-compose.override.yml

# Archivos de FastAPI / Uvicorn
*.pid

# Archivos de configuración sensibles
secrets.json
config.yaml
config.yml

# Archivos generados por migrations (depende si usas Alembic)
alembic/versions/*.pyc
